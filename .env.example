# NeuralStrike configuration.
# Copy to `.env` and edit. All keys can also be set via environment with the
# NEURALSTRIKE_ prefix (e.g. NEURALSTRIKE_ATTACKER_MODEL), per pydantic-settings.

# --- Local LLM brain (Attacker + Judge) ---
NEURALSTRIKE_OLLAMA_BASE_URL=http://localhost:11434
NEURALSTRIKE_ATTACKER_MODEL=deepseek-r1
NEURALSTRIKE_JUDGE_MODEL=llama3.1

# --- Remote target API keys (optional; only for `--target-type remote`) ---
NEURALSTRIKE_OPENAI_API_KEY=
NEURALSTRIKE_ANTHROPIC_API_KEY=

# --- Logging ---
# REDACT_LOGS=true will scrub strings that look like keys/credentials/tokens
# from log output before they reach the console.
NEURALSTRIKE_REDACT_LOGS=true