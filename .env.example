# NeuralStrike configuration.
# Copy to `.env` and edit. All keys can also be set via environment with the
# NEURALSTRIKE_ prefix (e.g. NEURALSTRIKE_ATTACKER_MODEL), per pydantic-settings.

# --- Local LLM brain (Attacker + Judge) ---
# Per Decision D1: the Judge is intentionally a STRONGER, DISTINCT model from
# the Attacker, so an attack run never scores itself and the judge is harder
# to confuse. The old `llama3.1` default was a fail-open bug (not installed)
# — fixed to deepseek-v3.1:671b-cloud with a startup reachability check.
NEURALSTRIKE_OLLAMA_BASE_URL=http://localhost:11434
NEURALSTRIKE_ATTACKER_MODEL=deepseek-r1
NEURALSTRIKE_JUDGE_MODEL=deepseek-v3.1:671b-cloud
# Ordered fallback chain tried when the Judge model is unreachable:
NEURALSTRIKE_JUDGE_MODEL_FALLBACKS=["kimi-k2.6:cloud","gpt-oss:120b-cloud","deepseek-r1:8b"]

# --- Reproducibility (Phase 0) ---
# Victim temperature is pinned to 0.0 so a replay with the same seed
# reproduces identical verdicts. Attacker temperature may be >0; the
# per-trial seed still makes it deterministic given the seed.
NEURALSTRIKE_VICTIM_TEMPERATURE=0.0
NEURALSTRIKE_ATTACKER_TEMPERATURE=0.7
# Skip the startup model-reachability check (tests / offline / explicit opt-in):
NEURALSTRIKE_SKIP_REACHABILITY_CHECK=false

# --- Remote target API keys (optional; only for `--target-type remote`) ---
NEURALSTRIKE_OPENAI_API_KEY=
NEURALSTRIKE_ANTHROPIC_API_KEY=

# --- Logging ---
# REDACT_LOGS=true will scrub strings that look like keys/credentials/tokens
# from log output before they reach the console.
NEURALSTRIKE_REDACT_LOGS=true